{
  "name": "stonemark-frontend",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "start:all": "concurrently \"npm:start:app\" \"npm:start:auth\" \"npm:start:profile\" \"npm:start:staff\"",
    "start:app": "ng serve app",
    "start:auth": "ng serve auth",
    "start:profile": "ng serve profile",
    "start:staff": "ng serve staff",
    "build": "ng build",
    "build:all": "npm run build:app && npm run build:auth && npm run build:profile && npm run build:staff",
    "build:app": "node ./node_modules/@angular/cli/bin/ng.js build app",
    "build:auth": "node ./node_modules/@angular/cli/bin/ng.js build auth",
    "build:profile": "node ./node_modules/@angular/cli/bin/ng.js build profile",
    "build:staff": "node ./node_modules/@angular/cli/bin/ng.js build staff",
    "watch": "ng build --watch --configuration development",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:ui": "vitest --ui",
    "test:e2e": "cypress open",
    "test:e2e:headless": "cypress run",
    "api:gen-models": "openapi-generator-cli generate -i http://localhost:8080/v3/api-docs -g typescript-angular -o ./projects/shared/src/lib/api --global-property models,modelDocs=false,modelTests=false --additional-properties=fileNaming=kebab-case",
    "start:prod": "npm run build:all && serve -s dist/app/browser",
    "start:prod:all": "npm run build:all && concurrently \"npm:serve:app\" \"npm:serve:auth\" \"npm:serve:profile\" \"npm:serve:staff\"",
    "serve:app": "serve -s dist/app/browser -l 4200",
    "serve:auth": "serve -s dist/auth/browser -l 4201",
    "serve:profile": "serve -s dist/profile/browser -l 4202",
    "serve:staff": "serve -s dist/staff/browser -l 4220"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^20.3.9",
    "@angular/common": "^20.3.0",
    "@angular/compiler": "^20.3.0",
    "@angular/forms": "^20.3.0",
    "@angular/material": "^20.2.12",
    "@angular/router": "^20.3.0",
    "@primeuix/themes": "^1.2.5",
    "@tailwindcss/postcss": "^4.1.16",
    "bootstrap-icons": "^1.13.1",
    "chart.js": "^4.5.1",
    "ol": "^10.6.1",
    "postcss": "^8.5.6",
    "primeicons": "^7.0.0",
    "primeng": "^20.3.0",
    "rxjs": "~7.8.0",
    "tailwindcss": "^4.1.16",
    "tailwindcss-primeui": "^0.6.1",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular/build": "^20.3.5",
    "@angular/cli": "^20.3.5",
    "@angular/compiler-cli": "^20.3.0",
    "@angular/platform-browser-dynamic": "^20.3.9",
    "@openapitools/openapi-generator-cli": "^2.25.2",
    "@types/ol": "^6.5.3",
    "@vitest/ui": "^3.2.4",
    "concurrently": "^8.2.2",
    "cypress": "^15.7.0",
    "jsdom": "^22.1.0",
    "ng-packagr": "^20.3.0",
    "typescript": "~5.9.2",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4"
  }
}
