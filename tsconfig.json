{
  "compileOnSave": false,
  "compilerOptions": {
    "strict": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "ES2022",
    "module": "preserve",
    "baseUrl": "./",
    "paths": {
      "@env/*": ["projects/shared/src/lib/core/environments/*"],
      "@core/*": ["projects/shared/src/lib/core/*"],
      "@layout/*": ["projects/shared/src/lib/layout/*"],
      "@shared/*": ["projects/shared/src/lib/shared/*"],
      "@features/*": ["projects/app/src/app/features/*"],
      "@services/*": ["projects/app/src/app/services/*"],
      "@api/*": ["projects/shared/src/lib/api/*"],
      "@assets/*": ["projects/shared/src/lib/assets/*"],
      "shared": ["./dist/shared"]
    }
  },
  "angularCompilerOptions": {
    "enableI18nLegacyMessageIdFormat": false,
    "strictInjectionParameters": true,
    "strictInputAccessModifiers": true,
    "typeCheckHostBindings": true,
    "strictTemplates": true
  },
  "files": [],
  "references": [
    {
      "path": "./tsconfig.app.json"
    },
    {
      "path": "./tsconfig.spec.json"
    },
    {
      "path": "./projects/app/tsconfig.app.json"
    },
    {
      "path": "./projects/app/tsconfig.spec.json"
    },
    {
      "path": "./projects/auth/tsconfig.app.json"
    },
    {
      "path": "./projects/auth/tsconfig.spec.json"
    },
    {
      "path": "./projects/profile/tsconfig.app.json"
    },
    {
      "path": "./projects/profile/tsconfig.spec.json"
    },
    {
      "path": "./projects/shared/tsconfig.lib.json"
    },
    {
      "path": "./projects/shared/tsconfig.spec.json"
    },
    {
      "path": "./projects/staff/tsconfig.app.json"
    },
    {
      "path": "./projects/staff/tsconfig.spec.json"
    }
  ]
}
